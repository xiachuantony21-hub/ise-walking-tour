# ── Stripe ────────────────────────────────────────────────────
# Get these from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...

# Get this after running: stripe listen --forward-to localhost:3000/api/webhook
STRIPE_WEBHOOK_SECRET=whsec_...

# ── Admin Panel ────────────────────────────────────────────────
# Password to log in to /admin
ADMIN_PASSWORD=change-me-to-something-secure

# Random secret for signing admin session tokens (min 32 chars)
ADMIN_JWT_SECRET=change-this-to-a-random-32-char-string

# ── Site URL ───────────────────────────────────────────────────
# Full URL of your site (no trailing slash)
# Development: http://localhost:3000
# Production:  https://your-domain.com
NEXT_PUBLIC_BASE_URL=http://localhost:3000
